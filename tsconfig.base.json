{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@headstrong/core": ["packages/core/src/index.ts"],
      "@headstrong/core/contracts": ["packages/core/src/contracts/index.ts"],
      "@headstrong/ai-gateway": ["packages/ai-gateway/src/index.ts"],
      "@headstrong/moderation": ["packages/moderation/src/index.ts"],
      "@headstrong/messaging": ["packages/messaging/src/index.ts"],
      "@headstrong/lms-adapters": ["packages/lms-adapters/src/index.ts"],
      "@headstrong/quest-composer": ["packages/quest-composer/src/index.ts"],
      "@headstrong/scene-planner": ["packages/scene-planner/src/index.ts"]
    }
  }
}
