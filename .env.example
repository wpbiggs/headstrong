NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

API_HOST=0.0.0.0
API_PORT=4000
JWT_SECRET=replace-with-at-least-32-characters
DATABASE_URL=postgres://postgres:postgres@localhost:5432/headstrong
REQUIRE_PARENT_APPROVAL_FOR_STUDENT_POSTS=true

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-me
TWILIO_FROM_NUMBER=+15555555555

OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=local-dev-key
QUEST_COMPOSER_PROVIDER=stub
QUEST_COMPOSER_MODEL=headstrong-quest-composer
ENABLE_MOODLE_ADAPTER=true
ENABLE_ERPNEXT_ADAPTER=true
ENABLE_COMPUTE_LEDGER=true
ENABLE_LTI_PROVIDER=false
ENABLE_LTI_CONSUMER=false
LTI_ISSUER=https://platform.example.com
LTI_CLIENT_ID=headstrong-lti-client
LTI_DEPLOYMENT_ID=headstrong-deployment
LTI_REDIRECT_URI=http://localhost:4000/integrations/lti/oidc/callback

ENABLE_CLEVER_ROSTERING=false
CLEVER_CLIENT_ID=replace-me
CLEVER_CLIENT_SECRET=replace-me
CLEVER_DISTRICT_ID=replace-me

ENABLE_CLASSLINK_ROSTERING=false
CLASSLINK_CLIENT_ID=replace-me
CLASSLINK_CLIENT_SECRET=replace-me
CLASSLINK_TENANT_ID=replace-me

ENABLE_GOOGLE_CLASSROOM=false
GOOGLE_CLASSROOM_CLIENT_ID=replace-me
GOOGLE_CLASSROOM_CLIENT_SECRET=replace-me
GOOGLE_CLASSROOM_REDIRECT_URI=http://localhost:4000/integrations/google-classroom/oauth/callback

ENABLE_OPEN_BADGES=false
OPEN_BADGES_ISSUER_URL=https://badges.example.com
OPEN_BADGES_ISSUER_NAME=Headstrong

MOODLE_BASE_URL=https://moodle.example.com
MOODLE_TOKEN=replace-me
ERPNEXT_BASE_URL=https://erpnext.example.com
ERPNEXT_API_KEY=replace-me
ERPNEXT_API_SECRET=replace-me
